{
  "name": "chatdump",
  "productName": "chatdump",
  "version": "1.0.1",
  "description": "Archive your AI chat conversations (Claude, ChatGPT, Gemini) as plain Markdown files on your Mac.",
  "author": {
    "name": "Yotaro Katayama",
    "email": "yotaro.katayama@combinatrix.ai"
  },
  "license": "MIT",
  "homepage": "https://github.com/combinatrix-ai/chatdump",
  "repository": {
    "type": "git",
    "url": "https://github.com/combinatrix-ai/chatdump"
  },
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "cli": "ELECTRON_RUN_AS_NODE=1 electron src/cli-entry.js",
    "mcp": "ELECTRON_RUN_AS_NODE=1 electron src/cli-entry.js mcp",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac --publish never",
    "dist:mas": "SKIP_NOTARIZE=1 electron-builder --mac mas",
    "dist:mas-dev": "SKIP_NOTARIZE=1 electron-builder --mac mas-dev",
    "test": "node --test test/",
    "lint": "biome check src test",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "knip": "knip"
  },
  "build": {
    "appId": "ai.combinatrix.chatdump",
    "productName": "chatdump",
    "copyright": "Copyright © 2026 Yotaro Katayama",
    "publish": [
      {
        "provider": "github",
        "owner": "combinatrix-ai",
        "repo": "chatdump"
      }
    ],
    "directories": {
      "buildResources": "build",
      "output": "dist-electron"
    },
    "files": [
      "src/**/*",
      "assets/iconTemplate.png",
      "assets/iconTemplate@2x.png",
      "assets/iconTemplate-syncing.png",
      "assets/iconTemplate-syncing@2x.png",
      "assets/providers/*.png",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/bin",
        "to": "bin"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": false,
      "extendInfo": {
        "ElectronTeamID": "3Y275A5TZ8"
      }
    },
    "mas": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "entitlements": "build/entitlements.mas.plist",
      "entitlementsInherit": "build/entitlements.mas.inherit.plist",
      "preAutoEntitlements": false,
      "extendInfo": {
        "ElectronTeamID": "3Y275A5TZ8"
      }
    },
    "masDev": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "entitlements": "build/entitlements.mas.plist",
      "entitlementsInherit": "build/entitlements.mas.inherit.plist",
      "preAutoEntitlements": false,
      "extendInfo": {
        "ElectronTeamID": "3Y275A5TZ8"
      }
    },
    "afterSign": "build/notarize.js",
    "dmg": {
      "title": "${productName} ${version}",
      "icon": "build/icon.icns"
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@electron/notarize": "^2.5.0",
    "electron": "^42.4.0",
    "electron-builder": "^25.0.0",
    "knip": "^6.7.0"
  }
}
